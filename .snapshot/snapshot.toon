  GET pages/cloze-exam.html,js/cloze-exam.js,pte_vocab.json|Firestore users/{uid}/examAttempts,pages/cloze-exam.html|partials/cloze-exam/cloze-exam.html
  GET partials/**/*.html,loadHtmlFunctions|fetchHtmlParts,,header|auth|home|practice|review|setting|favorites|exams|vocab-exam|cloze-exam
