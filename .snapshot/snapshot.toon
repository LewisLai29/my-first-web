  GET https://api.mymemory.translated.net/get,createLookupController,sessionStorage,partials/review/lookup-popup.html
m.ctrl[7]{name,path,desc,deps}:
  PteVocabApp,js/app.js,page boot review sessions popups favorites and vocabulary exam flow,config|auth|exams|favorites|lookup|speech|settings|vocab
  ClozeExamApp,js/cloze-exam.js,daily or endless multiple-choice cloze exam,date-utils|auth|exam-attempts|settings|vocab|config
  HomePopupController,js/home-popup-controller.js,open close and switch home feature popups,app.js
  ExamsController,js/exams.js,exam hub navigation and endless-mode toggle,settings
  FavoritesController,js/favorites.js,signed-in Firestore favorites subscription and mutation,firebase
  QuizAttemptsController,js/exam-attempts.js,per-user daily quiz or exam attempt persistence,firebase
  PopupScrollbarController,js/popup-scrollbar.js,custom popup and card scrollbar lifecycle,DOM
m.svc[18]{name,path,desc,deps}:
  boot,js/app.js,select page mode load partials wire auth and initialize page,config|html-functions|auth
  loadDeck,js/app.js,load seed shuffle and restore daily review deck,vocab|date-utils|settings|config
  showWord,js/app.js,render review card progress terms lookup speech and favorites,review-list|terms|lookup|speech|favorites
  loadQuizDeck,js/app.js,load signed-in daily vocabulary exam deck,vocab|exam-attempts|settings
  loadExamDeck,js/cloze-exam.js,build daily or endless cloze question deck,vocab|date-utils|settings
  setupAuthUI,js/auth.js,email password Google sign-in and sign-out UI,firebase|auth-modal
  ensureFirebaseServices,js/firebase.js,lazy-load Firebase app auth and Firestore compat SDK,firebase-config
  loadHtmlFunctions,js/html-functions.js,fetch and mount configured HTML fragments,config
  fetchHtmlParts,js/partial-loader.js,fetch partial HTML concurrently,Fetch API
  createLookupController,js/lookup.js,local-first example word lookup with online fallback,vocab|sessionStorage|MyMemory API
  createSpeechController,js/speech.js,voice selection and current-word speech,Web Speech API
  normalizeVocabItems,js/vocab.js,normalize vocabulary schema,date-utils
  pickDailyWords,js/vocab.js,deterministic daily vocabulary selection,date-utils
  shuffleWords,js/vocab.js,randomize selected deck order,
  wireSettingEvents,js/setting-ui.js,apply daily word count setting,settings
  renderFavoritesScreen,js/favorites-ui.js,render signed-in favorites list and controls,terms|favorites
  renderQuizResultScreen,js/vocab-exam-ui.js,render score and vocabulary exam answer analysis,
  renderReviewList,js/review-list.js,render reviewed word trail and jump controls,app.js
m.cmp[13]{name,path,desc,deps}:
  Header,partials/common/header.html,page title date home link and auth summary,auth|app
  AuthModal,partials/common/auth-modal.html,email password and Google authentication dialog,auth
